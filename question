import { createTheme } from '@mui/material';

const colorSchemes = {
  light: {
    scrollbar: {
      track: '#FAFAFA',
      thumb: '#C8C8C8',
      thumbHover: '#aaa',
    },
  },
  dark: {
    scrollbar: {
      track: '#333',
      thumb: '#666',
      thumbHover: '#888',
    },
  },
};

export const theme = createTheme({
  colorSchemes: {
    light: {
      palette: {
        primary: {
          main: 'rgb(0, 150, 94)',
        },
        secondary: {
          main: 'rgb(13, 218, 143)',
        },
        bnp: {
          main: 'rgb(0, 150, 94)',
        },
      },
    },

    dark: {
      palette: {
        primary: {
          main: 'rgb(13, 218, 143)',
        },
        secondary: {
          main: 'rgb(13, 218, 143)',
        },
        bnp: {
          main: 'rgb(0, 150, 94)',
        },
        background: {
          paper: '#343434',
          default: '#232323',
        },
      },
      components: {
        AppBar: {
          styleOverrides: {
            paper: {
              variants: [
                {
                  props: { elevation: 0 },
                  style: { '--Paper-overlay': 'none' },
                },
              ],
            },
          },
        },
      },
    },
  },

  typography: {
    fontFamily: 'Arial', // 'bnpp_sans, Arial',
    fontSize: 14,
  },

  components: {
    MuiCssBaseline: {
      styleOverrides: (props) => `
        *::-webkit-scrollbar {
          width: 0.4em;
          height: 0.6em;
        }
        *::-webkit-scrollbar-track {
          background: ${
            props.palette.mode === 'light'
              ? colorSchemes.light.scrollbar.track
              : colorSchemes.dark.scrollbar.track
          };
          border-radius: 8px;
        }
        *::-webkit-scrollbar-thumb {
          background-color: ${
            props.palette.mode === 'light'
              ? colorSchemes.light.scrollbar.thumb
              : colorSchemes.dark.scrollbar.thumb
          };
          border-radius: 8px;
        }
        *::-webkit-scrollbar-thumb:hover {
          background: ${
            props.palette.mode === 'light'
              ? colorSchemes.light.scrollbar.thumbHover
              : colorSchemes.dark.scrollbar.thumbHover
          };
        }
      `,
    },
  },
});


