// src/components/alerts/AlertItem.jsx
import React, { useState, useEffect, useCallback, useMemo } from 'react';
import { Box, Typography, Chip, useTheme, Rating } from '@mui/material';
import useFetcher from 'src/hooks/useFetcher';
import { ratingUrl } from 'src/utils/apiHelpers';

/**
 * Props:
 *   - alert   : the alert object (contains `id`, `objectID`, `rating`, …)
 *   - mutate  : SWR mutate function (bound to the alerts cache key)
 */
export default function AlertItem({ alert, mutate }) {
  const theme = useTheme();
  const fetcher = useFetcher();

  // -----------------------------------------------------------------
  // Local rating state – kept in sync with the alert object for
  // optimistic UI updates.
  // -----------------------------------------------------------------
  const [rating, setRating] = useState(alert.rating?.rating ?? 0);
  useEffect(() => {
    setRating(alert.rating?.rating ?? 0);
  }, [alert.rating]);

  // -----------------------------------------------------------------
  // Format the alert date as yyyy‑mm‑dd (no time part)
  // -----------------------------------------------------------------
  const formattedDate = useMemo(() => {
    if (!alert.date) return '';
    // Handles both ISO strings and Date objects
    const d = new Date(alert.date);
    // Guard against invalid dates
    if (Number.isNaN(d.getTime())) return alert.date;
    return d.toISOString().split('T')[0]; // “2026-02-06”
  }, [alert.date]);

  // -----------------------------------------------------------------
  // Build the payload exactly like the legacy code expects.
  // -----------------------------------------------------------------
  const buildPayload = useCallback(
    (newRating) => ({
      objectID: String(alert.objectID), // original primary key
      type: 'alert',
      rating1: newRating,
      comment: `${newRating} star${newRating > 1 ? 's' : ''}`,
      date: new Date().toISOString(),
    }),
    [alert.objectID]
  );

  // -----------------------------------------------------------------
  // Persist rating, then optimistically update the SWR cache.
  // -----------------------------------------------------------------
  const saveRating = async (newRating) => {
    try {
      const payload = buildPayload(newRating);
      const responseData = await fetcher(ratingUrl(), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const savedRating = responseData.rating; // { rating: <number> }

      // Optimistic UI – update local state instantly
      setRating(savedRating);

      // -------------------------------------------------------------
      // 1️⃣ Optimistically update the cached alerts list (no immediate fetch)
      // -------------------------------------------------------------
      mutate(
        (cachedAlerts) => {
          if (!cachedAlerts) return cachedAlerts;
          return cachedAlerts.map((a) =>
            a.id === alert.id
              ? {
                  ...a,
                  rating: {
                    rating: savedRating,
                    comment: `${savedRating} star${savedRating > 1 ? 's' : ''}`,
                  },
                }
              : a
          );
        },
        false // do NOT trigger a fetch right now
      );

      // -------------------------------------------------------------
      // 2️⃣ Trigger a background re‑validation so the cache eventually
      //    reflects the authoritative server value.
      // -------------------------------------------------------------
      mutate(); // <-- no second argument → SWR will re‑fetch silently
    } catch (e) {
      console.error('Failed to save rating:', e);
    }
  };

  const handleRatingChange = (event, newValue) => {
    // Optimistic UI – update instantly
    setRating(newValue);
    saveRating(newValue);
  };

  const isGeneral = alert.type === 'General';
  const isEBB = alert.type === 'EBB';

  // -----------------------------------------------------------------
  // Render
  // -----------------------------------------------------------------
  return (
    <Box
      p={2}
      mb={1}
      mr={1}
      border={`1px solid ${theme.palette.divider}`}
      borderRadius={2}
      sx={{
        backgroundColor: '#515151',
        height: '100%',
        display: 'flex',
        flexDirection: 'column',
        '&:hover': { backgroundColor: theme.palette.action.hover },
      }}>
      <Box sx={{ display: 'flex', justifyContent: 'space-between' }}>
        <Typography
          variant="body2"
          color="text.secondary"
          sx={{ fontSize: '12px !important' }}>
          {formattedDate}
        </Typography>

        <Chip
          label={alert.type}
          size="small"
          variant="filled"
          {...(alert.type === 'General' ? { color: 'primary' } : {})}
          sx={{
            fontSize: '12px !important',
            maxWidth: 120,
            overflow: 'hidden',
            textOverflow: 'ellipsis',
            whiteSpace: 'nowrap',
            '& .MuiChip-label': {
              overflow: 'hidden',
              textOverflow: 'ellipsis',
              whiteSpace: 'nowrap',
            },
            ...(alert.type === 'EBB' && {
              backgroundColor: '#f6ffb0',
              color: '#000',
            }),
            ...(alert.type !== 'General' &&
              alert.type !== 'EBB' && {
                backgroundColor: '#ffb0b0',
                color: '#000',
              }),
          }}
        />
      </Box>

      <Box sx={{ flexGrow: 1 }}>
        <Typography variant="body1" sx={{ mt: 1, fontSize: '12px !important' }}>
          {alert.desc}
        </Typography>
      </Box>

      {/* Rating UI ---------------------------------------------------------- */}
      <Box sx={{ mt: 1, display: 'flex', alignItems: 'center' }}>
        <Rating
          name={`alert-rating-${alert.id}`}
          value={rating}
          max={5}
          size="small"
          onChange={handleRatingChange}
        />
        <Typography
          variant="caption"
          sx={{ ml: 0.5, fontSize: '12px !important' }}>
          {rating === 0 ? 'Rate to archive' : `${rating} / 5`}
        </Typography>
      </Box>
    </Box>
  );
}

