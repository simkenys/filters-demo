import React from 'react';
import {
  Box,
  Typography,
  Button,
  IconButton,
  Divider,
  Collapse,
  useTheme,
} from '@mui/material';
import ExpandLessIcon from '@mui/icons-material/ExpandLess';
import ExpandMoreIcon from '@mui/icons-material/ExpandMore';
import TypeFilters from './TypeFilters';
import DateFilter from './DateFilter';
import ArchivedFilter from './ArchivedFilter'; // <-- new import

export default function FiltersSidebar(props) {
  const {
    clearAll,
    openTypes,
    setOpenTypes,
    openDate,
    setOpenDate,
    openGroups,
    setOpenGroups,
    // NEW – archive state
    archive,
    setArchive,
    // pass‑through props needed by children
    ...rest
  } = props;

  const theme = useTheme();

  return (
    <Box
      width={300}
      p={2}
      borderRight={`1px solid ${theme.palette.divider}`}
      sx={{
        position: 'sticky',
        top: 0,
        height: '100%',
        overflow: 'auto',
      }}>
      {/* Header ----------------------------------------------------------- */}
      <Box display="flex" justifyContent="space-between" alignItems="center">
        <Typography variant="h6" sx={{ fontSize: '12px !important' }}>
          Filters
        </Typography>
        <Button
          size="small"
          onClick={clearAll}
          sx={{ fontSize: '12px !important' }}>
          Clear
        </Button>
      </Box>

      {/* Alert Types ------------------------------------------------------- */}
      <Box mt={2}>
        <Box display="flex" justifyContent="space-between" alignItems="center">
          <Typography variant="subtitle2" sx={{ fontSize: '12px !important' }}>
            ALERT TYPE
          </Typography>
          <IconButton
            size="small"
            onClick={() => setOpenTypes(!openTypes)}
            sx={{ p: 0 }}>
            {openTypes ? <ExpandLessIcon /> : <ExpandMoreIcon />}
          </IconButton>
        </Box>

        <Collapse in={openTypes}>
          <Divider sx={{ mb: 1 }} />
          <TypeFilters
            {...rest}
            openGroups={openGroups}
            setOpenGroups={setOpenGroups}
          />
        </Collapse>
      </Box>

      {/* Date -------------------------------------------------------------- */}
      <Box mt={3}>
        <Box display="flex" justifyContent="space-between" alignItems="center">
          <Typography variant="subtitle2" sx={{ fontSize: '12px !important' }}>
            DATE
          </Typography>
          <IconButton
            size="small"
            onClick={() => setOpenDate(!openDate)}
            sx={{ p: 0 }}>
            {openDate ? <ExpandLessIcon /> : <ExpandMoreIcon />}
          </IconButton>
        </Box>

        <Collapse in={openDate}>
          <DateFilter {...rest} />
        </Collapse>
      </Box>

      {/* Archived – new accordion ------------------------------------------ */}
      <Box mt={3}>
        <Box display="flex" justifyContent="space-between" alignItems="center">
          <Typography variant="subtitle2" sx={{ fontSize: '12px !important' }}>
            ARCHIVED
          </Typography>
          {/* Re‑use the same open/close flag as Date (or create a new one if you prefer) */}
          <IconButton
            size="small"
            onClick={() => setOpenDate(!openDate)}
            sx={{ p: 0 }}>
            {openDate ? <ExpandLessIcon /> : <ExpandMoreIcon />}
          </IconButton>
        </Box>

        <Collapse in={openDate}>
          <ArchivedFilter archive={archive} setArchive={setArchive} />
        </Collapse>
      </Box>
    </Box>
  );
}

