import React from 'react';
import {
  Box,
  Typography,
  TextField,
  Chip,
  Paper,
  useTheme,
  Grid,
} from '@mui/material';
import AlertItem from './AlertItem';
import useUserInfo from 'src/hooks/useUserInfo';

export default function AlertsList({
  filteredAlerts,
  mutate,
  url,
  search,
  setSearch,
  selectedTypes,
  toggleType,
  toggleGroup,
  typeGroups,
}) {
  const theme = useTheme();

  // ---- get user info --------------------------------------------------------
  const { userInfo } = useUserInfo(); // { isImpersonating, positionUserName, … }

  // ---- title logic ---------------------------
  const pageTitle = (() => {
    const { isImpersonating, positionUserName, portfolioType } = userInfo;

    if (!isImpersonating) {
      // not impersonating – title depends on the current user's portfolio type
      switch (portfolioType) {
        case 'client':
          return 'My Alerts';
        case 'unit':
          return "My Entity's Alerts";
        default:
          return 'My Alerts'; // fallback
      }
    } else {
      // impersonating – we show the impersonated user’s name
      const name = positionUserName; // already the name of the impersonated position
      switch (portfolioType) {
        case 'client':
          return `Alerts of ${name}`;
        case 'unit':
          return `Entity's Alerts of ${name}`;
        default:
          return `Alerts of ${name}`; // fallback
      }
    }
  })();
  // ---------------------------------------------------------------------------

  // active chips (group‑level + individual) – same logic as before
  const groupChips = typeGroups
    .filter((g) => g.types.every((t) => selectedTypes.includes(t)))
    .map((g) => (
      <Chip
        size="small"
        key={g.name}
        label={g.name}
        onDelete={() => toggleGroup(g)}
        sx={{ fontSize: '12px !important' }}
      />
    ));

  const typeChips = selectedTypes
    .filter(
      (t) =>
        !typeGroups.some(
          (g) =>
            g.types.includes(t) &&
            g.types.every((tt) => selectedTypes.includes(tt))
        )
    )
    .map((type) => (
      <Chip
        size="small"
        key={type}
        label={type}
        onDelete={() => toggleType(type)}
        sx={{ fontSize: '12px !important' }}
      />
    ));

  return (
    <>
      {/* title */}
      <Box>
        <Typography
          variant="h6"
          gutterBottom
          sx={{
            fontSize: '15px !important',
            fontWeight: 'bold',
            color: theme.palette.primary.main,
            pb: 2,
          }}>
          {pageTitle}
        </Typography>
      </Box>

      {/* search + chips */}
      <Box>
        <TextField
          size="small"
          fullWidth
          placeholder="Search alerts..."
          value={search}
          onChange={(e) => setSearch(e.target.value)}
          sx={{
            mb: 2,
            '& .MuiInputBase-input': {
              fontSize: '12px !important',
              width: '100%',
            },
            '& .MuiInputLabel-root': { fontSize: '12px !important', mr: 1 },
          }}
        />

        <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 1, mb: 2 }}>
          {groupChips}
          {typeChips}
        </Box>

        <Typography
          variant="h6"
          gutterBottom
          sx={{ fontSize: '12px !important' }}>
          Alerts ({filteredAlerts.length})
        </Typography>
      </Box>

      {/* scrollable list */}
      <Paper
        elevation={0}
        sx={{
          flexGrow: 1,
          overflowY: 'auto',
          mt: 1,
          p: 0,
          backgroundColor: 'transparent',
        }}>
        <Grid container spacing={2} alignItems="stretch">
          {filteredAlerts.map((alert) => (
            <Grid key={alert.id} size={{ xs: 12, sm: 12, md: 6, lg: 4, xl: 3 }}>
              <AlertItem alert={alert} mutate={mutate} />
            </Grid>
          ))}
        </Grid>
      </Paper>
    </>
  );
}

