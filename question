import React from 'react';
import {
  Divider,
  RadioGroup,
  FormControlLabel,
  Radio,
  useTheme,
} from '@mui/material';

export default function ArchivedFilter({ archive, setArchive }) {
  const theme = useTheme();

  const smallControlSx = {
    fontSize: '12px !important',
    '& .MuiSvgIcon-root': { fontSize: '12px !important' },
  };

  return (
    <>
      <Divider sx={{ mb: 1 }} />
      <RadioGroup
        value={String(archive)}
        onChange={(e) => setArchive(Number(e.target.value))}
        sx={{ pl: 1 }}>
        {/* 0 – active only */}
        <FormControlLabel
          value="0"
          control={<Radio size="small" sx={smallControlSx} />}
          label="Active only"
          sx={{
            ml: 0,
            '& .MuiFormControlLabel-label': { fontSize: '12px !important' },
          }}
        />
        {/* 1 – archived only */}
        <FormControlLabel
          value="1"
          control={<Radio size="small" sx={smallControlSx} />}
          label="Archived only"
          sx={{
            ml: 0,
            '& .MuiFormControlLabel-label': { fontSize: '12px !important' },
          }}
        />
        {/* 2 – show everything */}
        <FormControlLabel
          value="2"
          control={<Radio size="small" sx={smallControlSx} />}
          label="All (active + archived)"
          sx={{
            ml: 0,
            '& .MuiFormControlLabel-label': { fontSize: '12px !important' },
          }}
        />
      </RadioGroup>
    </>
  );
}

