CREATE OR ALTER PROCEDURE MyC.GlobalSearch_Search
    @query NVARCHAR(100),
    @limit INT = 20,
	@entityType NVARCHAR(50) = NULL,
	@tokened BIT = 0
AS
BEGIN
    SET NOCOUNT ON;

    ------------------------------------------------------------
    -- 1. Guard clause
    ------------------------------------------------------------
    IF @query IS NULL OR LEN(LTRIM(RTRIM(@query))) < 2
    BEGIN
        SELECT TOP (0)
            entityType,
            entityId,
            title,
            subtitle
        FROM MyC.GlobalSearch;
        RETURN;
    END;

    ------------------------------------------------------------
    -- 2. Normalize query
    ------------------------------------------------------------
    DECLARE @q NVARCHAR(110);
    SET @q = LOWER(LTRIM(RTRIM(@query)));

    ------------------------------------------------------------
    -- 3. Search with correct prioritization
    ------------------------------------------------------------
    SELECT TOP (@limit)
        si.entityType,
        si.entityId,
        si.title,
        si.subtitle
    FROM MyC.GlobalSearch AS si
    WHERE si.searchText LIKE '%' + @q + '%'
		  AND (
			@entityType is NULL OR si.entityType = @entityType
		  )
    ORDER BY
        --------------------------------------------------------
        -- 1. Token prefix matches
        --------------------------------------------------------
        CASE
            WHEN si.searchText LIKE @q + '%' THEN 0
            WHEN si.searchText LIKE '% ' + @q + '%' THEN 1
            ELSE 2
        END,

        --------------------------------------------------------
        -- 2. Entity type priority
        --------------------------------------------------------
        CASE si.entityType
            WHEN 'Companies' THEN 1
            WHEN 'Company Phone Nrs' THEN 2
            WHEN 'Contacts' THEN 3
            ELSE 4
        END,

        --------------------------------------------------------
        -- 3. Stable ordering
        --------------------------------------------------------
        si.title ASC;
END;
GO


