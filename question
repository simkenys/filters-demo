import React from 'react';
import {
  Box,
  Typography,
  FormControlLabel,
  Checkbox,
  Collapse,
  IconButton,
  useTheme,
} from '@mui/material';
import ExpandLessIcon from '@mui/icons-material/ExpandLess';
import ExpandMoreIcon from '@mui/icons-material/ExpandMore';

export default function TypeFilters({
  typeGroups,
  selectedTypes,
  sortedTypes,
  facetedCounts,
  toggleType,
  toggleGroup,
  openGroups,
  setOpenGroups,
}) {
  const theme = useTheme();

  const smallControlSx = {
    fontSize: '12px !important',
    '& .MuiSvgIcon-root': { fontSize: '12px !important' },
  };

  return (
    <>
      {typeGroups.map((group) => {
        const groupOpen = openGroups[group.name];
        const groupCount = group.types.reduce(
          (sum, t) => sum + facetedCounts[t],
          0
        );
        const allSelected = group.types.every((t) => selectedTypes.includes(t));
        const someSelected =
          !allSelected && group.types.some((t) => selectedTypes.includes(t));

        return (
          <Box key={group.name} mb={1} pl={1.5}>
            {/* group header */}
            <Box
              display="flex"
              alignItems="center"
              justifyContent="space-between">
              <Typography
                variant="subtitle2"
                sx={{
                  fontSize: '12px !important',
                  fontWeight: 600,
                  mt: 1,
                  mb: 0.5,
                }}>
                {group.name} ({groupCount})
              </Typography>

              <Box display="flex" alignItems="center">
                <FormControlLabel
                  control={
                    <Checkbox
                      size="small"
                      sx={smallControlSx}
                      checked={allSelected}
                      indeterminate={someSelected}
                      onChange={() => toggleGroup(group)}
                    />
                  }
                  label=""
                  sx={{ margin: 0 }}
                />
                <IconButton
                  size="small"
                  onClick={() =>
                    setOpenGroups((prev) => ({
                      ...prev,
                      [group.name]: !prev[group.name],
                    }))
                  }
                  sx={{ p: 0, ml: 0.5 }}>
                  {groupOpen ? <ExpandLessIcon /> : <ExpandMoreIcon />}
                </IconButton>
              </Box>
            </Box>

            {/* types list */}
            <Collapse in={groupOpen}>
              {sortedTypes
                .filter((t) => group.types.includes(t))
                .map((type) => {
                  const count = facetedCounts[type];
                  const disabled = count === 0;
                  return (
                    <Box
                      key={type}
                      display="flex"
                      justifyContent="space-between"
                      alignItems="center"
                      sx={{
                        opacity: disabled
                          ? theme.palette.action.disabledOpacity
                          : 1,
                      }}>
                      <FormControlLabel
                        control={
                          <Checkbox
                            size="small"
                            sx={smallControlSx}
                            checked={selectedTypes.includes(type)}
                            onChange={() => toggleType(type)}
                            disabled={disabled}
                          />
                        }
                        label={type}
                        sx={{
                          '& .MuiFormControlLabel-label': {
                            fontSize: '12px !important',
                          },
                          margin: 0,
                        }}
                      />
                      <Typography
                        variant="body2"
                        color="text.secondary"
                        sx={{ fontSize: '12px !important' }}>
                        {count}
                      </Typography>
                    </Box>
                  );
                })}
            </Collapse>
          </Box>
        );
      })}
    </>
  );
}


